{
  "name": "jouleverne-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "build-only": "vite build --mode production",
    "preview": "vite preview",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "markdown-it": "^14.1.0",
    "pinia": "^3.0.4",
    "uuid": "^11.1.0",
    "vue": "^3.5.35",
    "vue-i18n": "^11.4.5",
    "vue-router": "^5.0.7"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.5",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^26.1.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.4.1",
    "eslint-plugin-vue": "~10.9.2",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/eslint-config-prettier": "^10.2.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "3.9.4",
    "typescript": "~6.0.3",
    "vite": "^8.0.16",
    "vue-tsc": "^3.3.3"
  }
}
