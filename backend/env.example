# App
ENVIRONMENT=DEV
RATE_LIMIT=100/minute
ALLOWED_ORIGINS=["http://localhost:5173"]

# AWS
AWS_REGION=eu-central-1

# Bedrock Agent — default knowledge base mode
AGENT_ID=your-agent-id
AGENT_ALIAS_ID=your-agent-alias-id

# Bedrock Agent — web search mode
AGENT_SEARCH_ID=your-search-agent-id
AGENT_SEARCH_ALIAS_ID=your-search-agent-alias-id

# S3 buckets
FEEDBACK_BUCKET=your-feedback-bucket
PDF_BUCKET=your-pdf-bucket
EXTRACTED_BUCKET=your-extracted-bucket
WEBSITE_BUCKET=your-website-bucket
FEDLEX_BUCKET=your-fedlex-bucket

# Auth — comma-separated Cognito group names (empty = no restriction)
ALLOWED_COGNITO_GROUPS=
